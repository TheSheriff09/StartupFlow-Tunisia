<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>

<BorderPane prefHeight="720.0" prefWidth="1280.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.GUI.ForumFeedController"
            stylesheets="@css/entrepreneur_dashboard.css"
            styleClass="root">

    <!-- Top bar -->
    <top>
        <HBox spacing="18" styleClass="topbar">
            <!-- Brand -->
            <VBox spacing="-2">
                <Label styleClass="brandTitle" text="StartupFlow" />
                <Label styleClass="brandSub" text="Tunisia" />
            </VBox>

            <Region HBox.hgrow="ALWAYS" />

            <!-- Nav -->
            <HBox spacing="28" styleClass="nav">
                <Label onMouseClicked="#onDashboard" styleClass="navLink" text="DashBoard" />
                <Label fx:id="navForumDashboard" onMouseClicked="#onForumDashboard" styleClass="navLink" text="Dashboard Forum" visible="false" managed="false"/>
                <Label fx:id="navUserManagement" onMouseClicked="#onUserManagement" styleClass="navLink" text="User Management" visible="false" managed="false"/>
                <Label onMouseClicked="#onStartup" styleClass="navLink" text="Startup" />
                <Label onMouseClicked="#onMentorship" styleClass="navLink" text="Mentorship" />
                <Label onMouseClicked="#onFunding" styleClass="navLink" text="Funding" />
                <Label onMouseClicked="#onFourm" styleClass="navLink navActive" text="Fourm" />
            </HBox>

            <Region HBox.hgrow="ALWAYS" />

            <!-- Action Buttons for Forum -->
            <HBox spacing="15" alignment="CENTER_RIGHT">
                 <Button text="+ New Post" styleClass="actionBtn" onAction="#addPost" style="-fx-text-fill: white; -fx-background-color: linear-gradient(to right, #7b61ff, #d7a1ff); -fx-background-radius: 16; -fx-padding: 8px 15px; -fx-font-weight: 800; -fx-cursor: hand;"/>
                
                 <!-- User dropdown -->
                 <MenuButton fx:id="userMenuBtn" styleClass="userBtn" text="User 1">
                     <items>
                         <MenuItem fx:id="miHeader" disable="true" text="USER 1" />
                         <MenuItem onAction="#onManageProfile" text="Manage Profile" />
                         <MenuItem onAction="#onStartups" text="Startups" />
                         <MenuItem onAction="#onSettings" text="Settings" />
                         <MenuItem fx:id="miDivider" disable="true" text="────────────" />
                         <MenuItem fx:id="miLogout" onAction="#onLogout" text="Log Out" />
                     </items>
                 </MenuButton>
            </HBox>
        </HBox>
    </top>

    <!-- CENTER FEED -->
    <center>
        <VBox spacing="20" style="-fx-background-color: #f4f4f4;">
            <padding>
                <Insets top="20" right="100" bottom="20" left="100"/>
            </padding>

            <!-- Header -->
            <HBox alignment="CENTER_LEFT" spacing="20">
                <Label text="Community Forum" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
            </HBox>

            <!-- Scrollable Feed -->
            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;">
                <VBox fx:id="postsContainer" spacing="15" >
                    <!-- Posts will be added here dynamically -->
                </VBox>
            </ScrollPane>
        </VBox>
    </center>

    <!-- BOTTOM NEWS TICKER -->
    <bottom>
        <HBox fx:id="newsTickerContainer" alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: #000000; -fx-padding: 5 10;">
            <Label text="LATEST POST:" style="-fx-text-fill: #d000ff; -fx-font-weight: bold; -fx-font-size: 14px;"/>
            <Pane fx:id="tickerPane" HBox.hgrow="ALWAYS" style="-fx-clip-shape: true;">
                <Label fx:id="newsTickerLabel" text="Loading..." style="-fx-text-fill: white; -fx-font-size: 14px;"/>
            </Pane>
        </HBox>
    </bottom>

</BorderPane>

