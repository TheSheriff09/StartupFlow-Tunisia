<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!--
    Startups Management — Admin Back-Office
    Full CRUD table with search, filters, pagination and themed action buttons.
-->
<VBox
        xmlns="http://javafx.com/javafx/21"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="tn.esprit.GUI.admin.AdminStartupsController"
        styleClass="admin-content-vbox"
        VBox.vgrow="ALWAYS">

    <!-- ═══ PAGE HEADER ═══ -->
    <HBox alignment="CENTER_LEFT" spacing="14">
        <VBox spacing="2" HBox.hgrow="ALWAYS">
            <Label text="Startups Management" styleClass="admin-page-title"/>
            <Label text="View, search, filter and manage all startup records."
                   styleClass="admin-page-subtitle"/>
        </VBox>

        <!-- FAB — Add Startup -->
        <Button fx:id="fabAdd"
                text="＋  Add Startup"
                styleClass="primary-button"
                onAction="#openAddDialog"
                style="-fx-font-size:13px; -fx-padding:11 24 11 24; -fx-background-radius:16;"/>
    </HBox>

    <!-- ═══ TOOLBAR: search + filters ═══ -->
    <HBox styleClass="admin-toolbar-wrap" spacing="10" alignment="CENTER_LEFT">

        <TextField fx:id="searchField"
                   promptText="🔍  Search by name, sector, stage…"
                   styleClass="admin-search-field"
                   onKeyReleased="#onSearch"/>

        <Region HBox.hgrow="ALWAYS"/>

        <Label text="Sector:" styleClass="activity-meta"/>
        <ComboBox fx:id="filterSector"
                  styleClass="admin-filter-combo"
                  onAction="#onFilter"
                  promptText="All Sectors"/>

        <Label text="Stage:" styleClass="activity-meta"/>
        <ComboBox fx:id="filterStage"
                  styleClass="admin-filter-combo"
                  onAction="#onFilter"
                  promptText="All Stages"/>

        <Label text="Status:" styleClass="activity-meta"/>
        <ComboBox fx:id="filterStatus"
                  styleClass="admin-filter-combo"
                  onAction="#onFilter"
                  promptText="All Statuses"/>

        <Button text="↺ Reset"
                styleClass="admin-back-btn"
                onAction="#onReset"
                style="-fx-font-size:12px; -fx-padding:7 14 7 14;"/>
    </HBox>

    <!-- ═══ TABLE ═══ -->
    <VBox styleClass="admin-table-wrap" VBox.vgrow="ALWAYS" spacing="0">

        <TableView fx:id="tableStartups"
                   styleClass="admin-table"
                   VBox.vgrow="ALWAYS"
                   columnResizePolicy="CONSTRAINED_RESIZE_POLICY_FLEX_LAST_COLUMN">

            <columns>
                <!-- ID -->
                <TableColumn fx:id="colId" text="ID" minWidth="52" maxWidth="68"
                             prefWidth="60" resizable="false"/>
                <!-- Name -->
                <TableColumn fx:id="colName" text="Name" minWidth="140"/>
                <!-- Sector -->
                <TableColumn fx:id="colSector" text="Sector" minWidth="110" maxWidth="160"/>
                <!-- Stage -->
                <TableColumn fx:id="colStage" text="Stage" minWidth="90" maxWidth="130"/>
                <!-- Status -->
                <TableColumn fx:id="colStatus" text="Status" minWidth="110" maxWidth="150"/>
                <!-- KPI -->
                <TableColumn fx:id="colKpi" text="KPI" minWidth="70" maxWidth="90"/>
                <!-- Funding -->
                <TableColumn fx:id="colFunding" text="Funding ($)" minWidth="100" maxWidth="140"/>
                <!-- Actions -->
                <TableColumn fx:id="colActions" text="Actions" minWidth="160" maxWidth="190"
                             resizable="false" sortable="false"/>
            </columns>

            <placeholder>
                <Label text="No startups found." styleClass="activity-meta"/>
            </placeholder>
        </TableView>

    </VBox>

    <!-- ═══ PAGINATION ═══ -->
    <HBox styleClass="admin-pagination-wrap" alignment="CENTER" spacing="10">
        <Button fx:id="btnPrev" text="‹ Prev" styleClass="admin-pagination-btn"
                onAction="#onPrev"/>
        <Label fx:id="pageInfo" text="Page 1 of 1" styleClass="admin-page-info"/>
        <Button fx:id="btnNext" text="Next ›" styleClass="admin-pagination-btn"
                onAction="#onNext"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="lblTotal" text="0 records" styleClass="activity-meta"/>
    </HBox>

</VBox>

