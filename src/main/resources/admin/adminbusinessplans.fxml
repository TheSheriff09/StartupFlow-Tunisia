<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!--
    Business Plans Management — Admin Back-Office
    Full CRUD table with search, filters, pagination and themed action buttons.
-->
<VBox
        xmlns="http://javafx.com/javafx/21"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="tn.esprit.GUI.admin.AdminBusinessPlansController"
        styleClass="admin-content-vbox"
        VBox.vgrow="ALWAYS">

    <!-- ═══ PAGE HEADER ═══ -->
    <HBox alignment="CENTER_LEFT" spacing="14">
        <VBox spacing="2" HBox.hgrow="ALWAYS">
            <Label text="Business Plans" styleClass="admin-page-title"/>
            <Label text="View, filter and manage all business plan records."
                   styleClass="admin-page-subtitle"/>
        </VBox>
    </HBox>

    <!-- ═══ TOOLBAR ═══ -->
    <HBox styleClass="admin-toolbar-wrap" spacing="10" alignment="CENTER_LEFT">

        <TextField fx:id="searchField"
                   promptText="🔍  Search by title, status, description…"
                   styleClass="admin-search-field"
                   onKeyReleased="#onSearch"/>

        <Region HBox.hgrow="ALWAYS"/>

        <Label text="Status:" styleClass="activity-meta"/>
        <ComboBox fx:id="filterStatus"
                  styleClass="admin-filter-combo"
                  onAction="#onFilter"
                  promptText="All Statuses"/>

        <Button text="↺ Reset"
                styleClass="admin-back-btn"
                onAction="#onReset"
                style="-fx-font-size:12px; -fx-padding:7 14 7 14;"/>
    </HBox>

    <!-- ═══ TABLE ═══ -->
    <VBox styleClass="admin-table-wrap" VBox.vgrow="ALWAYS" spacing="0">

        <TableView fx:id="tableBP"
                   styleClass="admin-table"
                   VBox.vgrow="ALWAYS"
                   columnResizePolicy="CONSTRAINED_RESIZE_POLICY_FLEX_LAST_COLUMN">

            <columns>
                <TableColumn fx:id="colId"       text="ID"       minWidth="52"  maxWidth="68"  prefWidth="60" resizable="false"/>
                <TableColumn fx:id="colTitle"    text="Title"    minWidth="160"/>
                <TableColumn fx:id="colStatus"   text="Status"   minWidth="110" maxWidth="150"/>
                <TableColumn fx:id="colFunding"  text="Funding ($)" minWidth="110" maxWidth="150"/>
                <TableColumn fx:id="colStartup"  text="Startup ID" minWidth="90"  maxWidth="110"/>
                <TableColumn fx:id="colCreated"  text="Created"  minWidth="100" maxWidth="130"/>
                <TableColumn fx:id="colUpdated"  text="Updated"  minWidth="100" maxWidth="130"/>
                <TableColumn fx:id="colActions"  text="Actions"  minWidth="130" maxWidth="160"
                             resizable="false" sortable="false"/>
            </columns>

            <placeholder>
                <Label text="No business plans found." styleClass="activity-meta"/>
            </placeholder>
        </TableView>

    </VBox>

    <!-- ═══ PAGINATION ═══ -->
    <HBox styleClass="admin-pagination-wrap" alignment="CENTER" spacing="10">
        <Button fx:id="btnPrev" text="‹ Prev" styleClass="admin-pagination-btn"
                onAction="#onPrev"/>
        <Label fx:id="pageInfo" text="Page 1 of 1" styleClass="admin-page-info"/>
        <Button fx:id="btnNext" text="Next ›" styleClass="admin-pagination-btn"
                onAction="#onNext"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="lblTotal" text="0 records" styleClass="activity-meta"/>
    </HBox>

</VBox>

