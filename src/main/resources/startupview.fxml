<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!--
    Root StackPane lets us layer the modal overlay on top of the dashboard
    without modifying the dashboard layout at all.
-->
<StackPane
        xmlns="http://javafx.com/javafx/21"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="tn.esprit.gui.startup.StartupViewController"
        stylesheets="@styles.css">

<BorderPane
        fx:id="mainContent"
        styleClass="root-pane">

    <!-- ═══════ NAVBAR ═══════ -->
    <top>
        <VBox>
            <!-- Navigation bar -->
            <HBox styleClass="navbar" alignment="CENTER_LEFT" spacing="0">
                <!-- Brand -->
                <VBox spacing="1">
                    <Label text="StartupFlow" styleClass="brand-title"/>
                    <Label text="Tunisia" styleClass="brand-sub"/>
                </VBox>

                <!-- Nav links -->
                <HBox styleClass="nav-links" alignment="CENTER" spacing="4">
                    <Label text="Home"       styleClass="nav-link"/>
                    <Label text="Startup"    styleClass="nav-link nav-active"/>
                    <Label text="Mentorship" styleClass="nav-link"/>
                    <Label text="Funding"    styleClass="nav-link"/>
                    <Label text="Forum"      styleClass="nav-link"/>
                </HBox>

                <Region HBox.hgrow="ALWAYS"/>

                <!-- Count + Admin + User button -->
                <Label fx:id="lblCount" text="0 startups" styleClass="count-badge">
                    <HBox.margin><Insets right="14"/></HBox.margin>
                </Label>
                <Button text="� Scan QR" onAction="#handleScanQR"
                        style="-fx-background-color:linear-gradient(to right,#7c3aed,#6d28d9);
                               -fx-text-fill:white; -fx-background-radius:20; -fx-padding:7 16;
                               -fx-font-weight:700; -fx-font-size:12px; -fx-cursor:hand;">
                    <tooltip><Tooltip text="Upload a QR code image to find a startup"/></tooltip>
                    <HBox.margin><Insets right="10"/></HBox.margin>
                </Button>
                <Button text="�📈 AI Forecast" onAction="#openFinancialForecast"
                        style="-fx-background-color:linear-gradient(to right,#059669,#0d9488);
                               -fx-text-fill:white; -fx-background-radius:20; -fx-padding:7 16;
                               -fx-font-weight:700; -fx-font-size:12px; -fx-cursor:hand;">
                    <tooltip><Tooltip text="Generate an AI-powered 12-month financial forecast"/></tooltip>
                    <HBox.margin><Insets right="10"/></HBox.margin>
                </Button>
                <Button text="💱 Currency" onAction="#openCurrencyConverter"
                        style="-fx-background-color:linear-gradient(to right,#0369a1,#0284c7);
                               -fx-text-fill:white; -fx-background-radius:20; -fx-padding:7 16;
                               -fx-font-weight:700; -fx-font-size:12px; -fx-cursor:hand;">
                    <tooltip><Tooltip text="Convert funding amounts to USD and EUR"/></tooltip>
                    <HBox.margin><Insets right="10"/></HBox.margin>
                </Button>
                <Button text="⚙ Admin" styleClass="admin-back-btn"
                        onAction="#openAdminDashboard">
                    <tooltip><Tooltip text="Open the Admin Dashboard"/></tooltip>
                    <HBox.margin><Insets right="10"/></HBox.margin>
                </Button>
                <Button fx:id="themeToggle" text="☀" styleClass="theme-toggle"
                        onAction="#toggleTheme">
                    <tooltip><Tooltip text="Toggle Dark / Light mode"/></tooltip>
                    <HBox.margin><Insets right="10"/></HBox.margin>
                </Button>
                <Button text="User 1" styleClass="user-btn"/>
            </HBox>

            <!-- Centered search bar + sort selector -->
            <HBox styleClass="search-wrap" alignment="CENTER" spacing="12">
                <TextField
                        fx:id="searchField"
                        promptText="🔍  Search startups…"
                        styleClass="search-field"/>
                <ComboBox fx:id="sortCombo" onAction="#onSortChanged"
                          promptText="Sort by…"
                          styleClass="search-field"
                          prefWidth="170"/>
            </HBox>
        </VBox>
    </top>

    <!-- ═══════ BOARD PANEL + CARDS ═══════ -->
    <center>
        <StackPane>
            <padding>
                <Insets top="14" right="36" bottom="14" left="36"/>
            </padding>
            <VBox styleClass="board-panel">
                <ScrollPane fitToWidth="true" styleClass="scroll-area" VBox.vgrow="ALWAYS">
                    <FlowPane
                            fx:id="cardsContainer"
                            hgap="24" vgap="24"
                            styleClass="cards-pane">
                        <padding>
                            <Insets top="30" right="30" bottom="30" left="30"/>
                        </padding>
                    </FlowPane>
                </ScrollPane>
            </VBox>
        </StackPane>
    </center>

    <!-- ═══════ FAB (circular) ═══════ -->
    <bottom>
        <HBox alignment="CENTER_RIGHT" styleClass="fab-bar">
            <Button
                    fx:id="fabBtn"
                    text="＋"
                    styleClass="fab-btn"
                    onAction="#openAddDialog"/>
        </HBox>
    </bottom>

</BorderPane>

<!-- Modal overlay layer — populated at runtime by StartupViewController -->
<StackPane
        fx:id="modalLayer"
        visible="false"
        managed="false"
        maxWidth="Infinity"
        maxHeight="Infinity"
        StackPane.alignment="CENTER"/>

</StackPane>
