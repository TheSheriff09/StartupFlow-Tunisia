<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox
        xmlns="http://javafx.com/javafx/21"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="tn.esprit.gui.startup.StartupCardController"
        fx:id="cardRoot"
        styleClass="startup-card"
        prefWidth="310"
        minHeight="228"
        spacing="0">

    <!-- Content area (padded) -->
    <VBox spacing="0" VBox.vgrow="ALWAYS">
        <padding>
            <Insets top="26" right="24" bottom="20" left="24"/>
        </padding>

        <!-- Title -->
        <Label fx:id="lblName" styleClass="card-name" text="Startup Name" wrapText="true"/>

        <!-- Thin divider -->
        <Region styleClass="card-divider">
            <VBox.margin><Insets top="14" bottom="14"/></VBox.margin>
        </Region>

        <!-- Bullet info -->
        <VBox spacing="8">
            <Label fx:id="lblSector"      styleClass="card-bullet" text=""/>
            <Label fx:id="lblDescription" styleClass="card-bullet" text=""/>
            <Label fx:id="lblStatus"      styleClass="card-bullet" text=""/>
            <Label fx:id="lblFunding"     styleClass="card-bullet" text=""/>
            <Label fx:id="lblDate" visible="false" managed="false" text=""/>
        </VBox>

        <Region VBox.vgrow="ALWAYS"/>
    </VBox>

    <!-- Action bar — hidden by default, revealed on hover -->
    <HBox fx:id="btnGroup" styleClass="card-action-bar" alignment="CENTER" spacing="8" opacity="0">
        <Button fx:id="btnEdit"      text="✏  Edit"    styleClass="btn-edit"    onAction="#handleEdit"/>
        <Button fx:id="btnDelete"    text="🗑  Delete"  styleClass="btn-delete"   onAction="#handleDelete"/>
        <Button fx:id="btnViewPlans" text="📋  Plans"   styleClass="btn-plans"    onAction="#handleViewPlans"/>
    </HBox>

</VBox>
