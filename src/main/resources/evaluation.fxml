<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.GUI.EvaluationController"
            prefWidth="1300" prefHeight="850">

    <children>
        <AnchorPane layoutX="40" layoutY="40"
                    prefWidth="1220" prefHeight="770"
                    styleClass="main-card">

            <children>
                <Label text="Evaluation"
                       layoutX="30" layoutY="25"
                       style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #7B61FF;"/>

                <VBox spacing="12" layoutX="30" layoutY="80" prefWidth="250">
                    <TextField fx:id="txtFundingApplicationId" promptText="Funding Application ID"/>
                    <TextField fx:id="txtScore" promptText="Score"/>
                    <TextField fx:id="txtDecision" promptText="Decision"/>

                    <TextField fx:id="txtEvaluationComments" promptText="Evaluation Comments"/>

                    <!-- Translation -->
                    <HBox spacing="8">
                        <ComboBox fx:id="cmbLanguage" promptText="Language" prefWidth="140"/>
                        <Button text="Translate" onAction="#translateComments" prefWidth="100"/>
                    </HBox>

                    <!-- OCR attachment -->
                    <HBox spacing="8">
                        <TextField fx:id="txtOcrFile" promptText="Attach PDF/Image for OCR" prefWidth="160"/>
                        <Button text="Browse" onAction="#browseOcrFile" prefWidth="80"/>
                    </HBox>
                    <Button text="OCR Extract → Comments" onAction="#ocrExtractToComments" prefWidth="240"/>

                    <TextField fx:id="txtEvaluatorId" promptText="Evaluator ID"/>
                    <TextField fx:id="txtRiskLevel" promptText="Risk Level"/>
                    <TextField fx:id="txtFundingCategory" promptText="Funding Category"/>

                    <VBox spacing="10" alignment="CENTER">
                        <Button text="Add Evaluation" onAction="#addEvaluation" prefWidth="200"/>
                        <HBox spacing="10" alignment="CENTER">
                            <Button text="Update" onAction="#updateEvaluation" style="-fx-padding: 8 15;"/>
                            <Button text="Delete" onAction="#deleteEvaluation" styleClass="button-danger"/>
                        </HBox>
                    </VBox>
                </VBox>

                <TextField fx:id="searchField"
                           styleClass="search-field"
                           promptText="🔍 Search evaluations..."
                           layoutX="310" layoutY="25"
                           prefWidth="880"/>

                <TableView fx:id="tableEvaluations"
                           layoutX="310" layoutY="80"
                           prefWidth="880"
                           prefHeight="660">
                    <columns>
                        <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                        <TableColumn fx:id="colFundingApplicationId" text="FundingApp ID" prefWidth="120"/>
                        <TableColumn fx:id="colScore" text="Score" prefWidth="70"/>
                        <TableColumn fx:id="colDecision" text="Decision" prefWidth="110"/>
                        <TableColumn fx:id="colEvaluationComments" text="Comments" prefWidth="170"/>
                        <TableColumn fx:id="colEvaluatorId" text="Evaluator ID" prefWidth="100"/>
                        <TableColumn fx:id="colRiskLevel" text="Risk Level" prefWidth="110"/>
                        <TableColumn fx:id="colFundingCategory" text="Category" prefWidth="120"/>
                    </columns>
                </TableView>

                <HBox spacing="10" layoutX="700" layoutY="25">
                    <Button text="Export PDF" onAction="#exportPdf" style="-fx-padding: 8 15;"/>
                    <Button text="Go to Applications" onAction="#backToDashboard" style="-fx-padding: 8 15;"/>
                </HBox>

            </children>
        </AnchorPane>
    </children>
</AnchorPane>
