<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="614.0" prefWidth="1128.0" styleClass="root" stylesheets="@css/swot.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.GUI.SwotController">

    <!-- Top bar -->
    <HBox spacing="18" styleClass="topbar" AnchorPane.leftAnchor="28" AnchorPane.rightAnchor="28" AnchorPane.topAnchor="18">
        <VBox spacing="-2">
            <Label styleClass="brandTitle" text="StartupFlow" />
            <Label styleClass="brandSub" text="Tunisia" />
        </VBox>
      <Button fx:id="generateBtn1" onAction="#onBack" prefHeight="35.0" prefWidth="157.0" styleClass="saveBtn" text="Back" />

        <Region HBox.hgrow="ALWAYS" />

        <HBox spacing="28" styleClass="nav">
            <Label styleClass="navLink navActive" text="AI SWOT" />
        </HBox>

        <Region HBox.hgrow="ALWAYS" />

        <MenuButton fx:id="userMenuBtn" styleClass="userBtn" text="User 1">
            <items>
                <MenuItem fx:id="miHeader" disable="true" text="USER 1" />
                <MenuItem onAction="#onManageProfile" text="Manage Profile" />
                <MenuItem onAction="#onStartups" text="Startups" />
                <MenuItem onAction="#onSettings" text="Settings" />
                <MenuItem fx:id="miDivider" disable="true" text="────────────" />
                <MenuItem fx:id="miLogout" onAction="#onLogout" text="Log Out" />
            </items>
        </MenuButton>
    </HBox>

    <!-- Main card -->
    <StackPane styleClass="mainCard" AnchorPane.bottomAnchor="60" AnchorPane.leftAnchor="70" AnchorPane.rightAnchor="70" AnchorPane.topAnchor="120">

        <VBox spacing="14" styleClass="contentBox" StackPane.alignment="CENTER">

            <Label styleClass="sectionTitle" text="AI SWOT" />
            <Label styleClass="sectionSub" text="Generate a clean 4-part SWOT for your startup" />
            <Region styleClass="titleUnderline" />

            <HBox spacing="12" styleClass="row">
                <ComboBox fx:id="startupCombo" prefWidth="420.0" promptText="Select a Startup..." styleClass="pillField" />
                <Button fx:id="generateBtn" onAction="#onGenerate" styleClass="saveBtn" text="🤖 Generate" />
            </HBox>

            <GridPane prefHeight="290.0" styleClass="swotGrid">
                <columnConstraints>
                    <ColumnConstraints hgrow="ALWAYS" percentWidth="50.0" />
                    <ColumnConstraints hgrow="ALWAYS" percentWidth="50.0" />
                </columnConstraints>
                <rowConstraints>
                    <RowConstraints percentHeight="50.0" vgrow="ALWAYS" />
                    <RowConstraints percentHeight="50.0" vgrow="ALWAYS" />
                </rowConstraints>

                <VBox spacing="8" styleClass="swotCard" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <Label styleClass="swotTitle swotStrength" text="Strengths" />
                    <ListView fx:id="strengthsList" styleClass="swotList" />
                </VBox>

                <VBox spacing="8" styleClass="swotCard" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <Label styleClass="swotTitle swotWeakness" text="Weaknesses" />
                    <ListView fx:id="weaknessesList" styleClass="swotList" />
                </VBox>

                <VBox spacing="8" styleClass="swotCard" GridPane.columnIndex="0" GridPane.rowIndex="1">
                    <Label styleClass="swotTitle swotOpportunity" text="Opportunities" />
                    <ListView fx:id="opportunitiesList" styleClass="swotList" />
                </VBox>

                <VBox spacing="8" styleClass="swotCard" GridPane.columnIndex="1" GridPane.rowIndex="1">
                    <Label styleClass="swotTitle swotThreat" text="Threats" />
                    <ListView fx:id="threatsList" styleClass="swotList" />
                </VBox>
            </GridPane>

            <Label fx:id="statusLabel" styleClass="msg" text="" />
        </VBox>

    </StackPane>

</AnchorPane>

