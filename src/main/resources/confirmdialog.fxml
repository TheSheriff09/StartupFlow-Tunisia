<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!--
    confirmdialog.fxml — Reusable glass popup overlay.
    Used for: delete confirmations, error alerts, success notices.
    Configured at runtime by ConfirmDialogController.configure().
-->
<StackPane
        xmlns="http://javafx.com/javafx/21"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="tn.esprit.GUI.popup.ConfirmDialogController"
        fx:id="overlayRoot"
        styleClass="modal-overlay"
        alignment="CENTER"
        maxWidth="Infinity"
        maxHeight="Infinity">

    <!-- Dark backdrop — clicking outside dismisses the dialog -->
    <Pane
            styleClass="modal-backdrop"
            onMouseClicked="#onCancel"
            maxWidth="Infinity"
            maxHeight="Infinity"/>

    <!-- ── Glass card ── -->
    <VBox fx:id="modalCard" styleClass="modal-card popup-card" spacing="0" maxWidth="420">

        <!-- Title bar -->
        <HBox fx:id="titleBar" styleClass="modal-title-bar popup-title-bar" alignment="CENTER_LEFT" spacing="14">
            <Label fx:id="iconLabel"  text="⚠" styleClass="popup-icon"/>
            <Label fx:id="titleLabel" text="Confirm" styleClass="modal-title"/>
        </HBox>

        <!-- Body -->
        <VBox styleClass="popup-body" spacing="0">
            <Label
                    fx:id="messageLabel"
                    text="Are you sure?"
                    styleClass="popup-message"
                    wrapText="true"
                    maxWidth="Infinity"/>
        </VBox>

        <!-- Button bar -->
        <HBox fx:id="buttonBar" styleClass="modal-btn-bar popup-btn-bar" alignment="CENTER_RIGHT" spacing="12">
            <Button fx:id="cancelBtn"  text="Cancel"  styleClass="modal-cancel-btn"  onAction="#onCancel"  visible="true"/>
            <Button fx:id="confirmBtn" text="Confirm" styleClass="popup-confirm-btn" onAction="#onConfirm"/>
        </HBox>

    </VBox>
</StackPane>

